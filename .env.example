# Copy this file to .env and fill in your values
# .env is gitignored and cursorignored — never commit it

# ─────────────────────────────────────────────────────────────────────────
# Upstream provider API keys (used by presets for $ANTHROPIC_API_KEY etc.)
# These are NOT read by the proxy itself; config.jsonc interpolates them.
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# CCR_ env vars — flat container overrides (v2.1+)
# Each maps to exactly one config.jsonc key.  No __ delimiter magic.
# Set = value.  Missing = ignored.  Invalid = logged and skipped.
# ─────────────────────────────────────────────────────────────────────────

# Core server settings
# CCR_HOST=127.0.0.1
# CCR_PORT=3456
# CCR_APIKEY=your-secret-key
# CCR_API_TIMEOUT_MS=600000
# CCR_LOG_LEVEL=info
# CCR_NON_INTERACTIVE_MODE=false
# CCR_PROXY_URL=

# Router model refs ("provider,model" format)
# CCR_ROUTER_DEFAULT=anthropic,claude-sonnet-4-6
# CCR_ROUTER_BACKGROUND=ollama,qwen2.5-coder:latest
# CCR_ROUTER_THINK=deepseek,deepseek-reasoner
# CCR_ROUTER_LONG_CONTEXT=openrouter,google/gemini-2.5-pro-preview
# CCR_ROUTER_LONG_CONTEXT_THRESHOLD=60000
# CCR_ROUTER_WEB_SEARCH=openrouter,google/gemini-2.5-flash:online
# CCR_ROUTER_IMAGE=anthropic,claude-sonnet-4-6

# Plugins — pass as a JSON array literal
# CCR_PLUGINS=[{"name":"metrics","enabled":true,"options":{"port":9464}}]
