{
  // ── Hop-proxy config for gascity-runner ──────────────────────────────────
  // This CCR runs *inside* a container and forwards to the host CCR.
  // The host CCR (ccr-local, port 3456) has the real upstream provider keys.
  //
  // Chain:  Claude Code → ccr-hop (Docker, port 3457 on host) → ccr-local (:3456) → upstream
  //
  // The hop label "gascity" appears in Prometheus metrics so we can track
  // how much traffic flows through the hop-proxy path.
  // ─────────────────────────────────────────────────────────────────────────

  "APIKEY": "hop-secret",
  "HOST": "0.0.0.0",
  "PORT": "3456",
  "LOG_LEVEL": "info",
  "API_TIMEOUT_MS": 600000,
  "NON_INTERACTIVE_MODE": true,
  "PROXY_HOP": "gascity",

  // ── Providers ────────────────────────────────────────────────────────────
  // Each provider points to the *host* CCR, not the upstream API directly.
  // The host CCR then routes to the real provider using its own config.
  "Providers": [
    {
      "name": "anthropic",
      "api_base_url": "http://host.docker.internal:3456/v1/messages",
      "api_key": "hop-secret",
      "models": [
        "claude-opus-4-7",
        "claude-sonnet-4-6",
        "claude-haiku-4-5-20251001"
      ],
      "transformer": { "use": ["anthropic"] }
    },
    {
      "name": "gemini",
      "api_base_url": "http://host.docker.internal:3456/v1beta/models/",
      "api_key": "hop-secret",
      "models": [
        "gemini-2.5-flash",
        "gemini-2.5-pro"
      ],
      "transformer": { "use": ["gemini"] }
    }
  ],

  "Router": {
    "default": "anthropic,claude-sonnet-4-6",
    "background": "anthropic,claude-sonnet-4-6",
    "think": "anthropic,claude-opus-4-7",
    "longContext": "anthropic,claude-opus-4-7",
    "longContextThreshold": 60000
  }
}
